# Backend database
# Leave unset to use local SQLite, or set to PostgreSQL for a shared/dev/prod database.
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/bowei_ai_dashboard

# Enable dev seeding and schema bootstrap on startup
BOWEI_DEV_MODE=true

# Optional LLM switch
BOWEI_USE_LLM=false
LLM_PROVIDER=anthropic

# Optional provider keys used by the extractor
ANTHROPIC_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
ZHIPUAI_API_KEY=
